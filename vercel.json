{
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    }
  ],
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html","source": "/proxy-api/:path*",
      "destination": "https://jboycreator56.ct.ws/api/:path*" }
  ]
}
